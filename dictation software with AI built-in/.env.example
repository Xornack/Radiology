# Local environment variables for the dictation app.
# Copy this file to `.env` in the same directory and fill in the values
# you need. `.env` is gitignored; `.env.example` (this file) is a safe
# template that can be committed.
#
# Any variable set in your actual shell environment wins over this file —
# these values are fallbacks only.

# --- Hugging Face ----------------------------------------------------------
# Access token for gated models (e.g. google/medasr, which requires you to
# accept the Health AI Developer Foundations terms once on the HF website).
# Get a token from https://huggingface.co/settings/tokens — a "Read" token
# is enough. MedASR's first-run download uses this automatically.
# HF_TOKEN=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

# --- STT backend ----------------------------------------------------------
# Which speech-to-text engine to use at startup. The UI dropdown lets you
# switch at runtime; this only sets the initial choice.
# One of: whisper-local-cpu (default), whisper-local-gpu, sensevoice, medasr.
# STT_BACKEND=medasr

# faster-whisper model size, if you don't want the default base.en.
# Any variant faster-whisper knows: tiny.en / small.en / medium.en / large-v3.
# WHISPER_MODEL=small.en

# --- Post-processing -------------------------------------------------------
# Radiology vocabulary correction ("plural" -> "pleural" etc.).
# Set to 0 / false / off to disable by default.
# RADIOLOGY_MODE=1

# --- LLM (Generate Impression button) --------------------------------------
# OpenAI-compatible completions endpoint for impression generation.
# LLM_URL=http://localhost:8001/v1/completions

# --- HID dictation mic -----------------------------------------------------
# Override the USB vendor/product IDs if you don't have a Nuance PowerMic II-NS
# (the default 0x0554 / 0x1001). Philips SpeechMike: 0x0911 / 0x0c1c.
# SPEECHMIKE_VID=0x0911
# SPEECHMIKE_PID=0x0c1c
